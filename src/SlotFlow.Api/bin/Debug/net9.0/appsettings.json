{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=slotflow;Username=slotflow_user;Password=slotflow_pass"
  },
  "ExpiryJob": {
    "IntervalSeconds": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  }
}